{
  "go_services": {
    "gateway": {
      "cmd_path": "cmd/gateway",
      "port": 8082,
      "k8s_resource": "gateway"
    },
    "item": {
      "cmd_path": "cmd/item",
      "port": 8080,
      "k8s_resource": "item-service"
    },
    "masterdata": {
      "cmd_path": "cmd/masterdata",
      "port": 8084,
      "k8s_resource": "masterdata-service"
    },
    "raid-lobby": {
      "cmd_path": "cmd/raid-lobby",
      "port": 8086,
      "k8s_resource": "raid-lobby-service"
    },
    "lobby": {
      "cmd_path": "cmd/lobby",
      "port": 8089,
      "k8s_resource": "lobby-service"
    },
    "capture": {
      "cmd_path": "cmd/capture",
      "port": 8088,
      "k8s_resource": "capture-service"
    }
  },
  "custom_services": {
    "auth-service": {
      "port": 8090,
      "k8s_resource": "auth-service"
    }
  },
  "special": {
    "frontend": {
      "port": 5173,
      "k8s_resource": "frontend",
      "build_args": {
        "VITE_API_BASE_URL": "http://localhost:30081"
      },
      "extra_resource_deps": [
        "buf-generate"
      ]
    }
  }
}
